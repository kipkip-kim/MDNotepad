{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDNotepad",
  "version": "0.1.0",
  "identifier": "com.mdnotepad.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MDNotepad",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown File"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "Text File"
      }
    ]
  }
}
